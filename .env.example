# Environment configuration template
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Keys marked [REQUIRED] must be set before the application will start.
# Keys marked [OPTIONAL] have safe defaults and may be omitted.

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai              # [REQUIRED] openai | google | groq | openrouter
LLM_MODEL=gpt-4o-mini            # [OPTIONAL] model name (falls back to provider default)
TEMPERATURE=0.3                  # [OPTIONAL] 0.0–1.0

# OpenAI — always required (embeddings use OpenAI regardless of LLM_PROVIDER)
OPENAI_API_KEY=sk-...            # [REQUIRED] https://platform.openai.com/api-keys

# Google Gemini
# GOOGLE_API_KEY=...             # [REQUIRED if LLM_PROVIDER=google] https://aistudio.google.com/apikey

# Groq
# GROQ_API_KEY=gsk_...           # [REQUIRED if LLM_PROVIDER=groq] https://console.groq.com/keys

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...   # [REQUIRED if LLM_PROVIDER=openrouter] https://openrouter.ai/keys

# ── Search / Retrieval (Tavily) ───────────────────────────────────────────────
TAVILY_API_KEY=tvly-...          # [REQUIRED] https://app.tavily.com
TAVILY_SEARCH_DEPTH=basic        # [OPTIONAL] ultra-fast | fast | basic | advanced (default: basic)
TAVILY_NUM_RESULTS=5             # [OPTIONAL] results per query, 1–10 (default: 5)
TAVILY_INCLUDE_ANSWER=true       # [OPTIONAL] include LLM-generated answer (default: true)
TAVILY_INCLUDE_USAGE=true        # [OPTIONAL] include API credit usage metadata (default: true)

# ── MongoDB (corpus) ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017  # [REQUIRED] Atlas or local MongoDB URI
MONGODB_DB=revisao_agents              # [OPTIONAL] database name (default: revisao_agents)
MONGODB_COLLECTION=chunks              # [OPTIONAL] collection name (default: chunks)

# ── LangGraph persistence ─────────────────────────────────────────────────────
CHECKPOINT_TYPE=memory           # [OPTIONAL] memory | sqlite (default: memory)
CHECKPOINT_PATH=runtime/checkpoints/checkpoints.db  # [OPTIONAL] path for sqlite backend

# ── MLflow observability ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///./runtime/mlruns/mlflow.db  # [OPTIONAL] tracking backend URI (default: local SQLite)

# ── Output paths ──────────────────────────────────────────────────────────────
PLANS_DIR=./runtime/plans                # [OPTIONAL] directory for generated plans
REVIEWS_DIR=./runtime/reviews            # [OPTIONAL] directory for generated reviews
SEARCH_LOGS_DIR=./runtime/search_logs    # [OPTIONAL] directory for Tavily search logs
CHUNKS_CACHE_DIR=./runtime/chunks_cache  # [OPTIONAL] directory for chunk cache files
